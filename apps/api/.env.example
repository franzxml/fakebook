DATABASE_URL="file:./prisma/dev.db"
PORT="3000"
CORS_ORIGIN="http://localhost:5173"
ADMIN_USERS_KEY="your-secret-key"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
UPLOADS_BUCKET="fakebook-user-content-example"
UPLOADS_PUBLIC_BASE_URL="https://fakebook-user-content-example.s3.us-east-1.amazonaws.com"
WEBSOCKET_CONNECTIONS_TABLE="fakebook-websocket-connections"
WEBSOCKET_API_ENDPOINT="https://your-websocket-api.execute-api.us-east-1.amazonaws.com/prod"

# Production example for AWS Lambda.
# Use a persistent libSQL/Turso database URL. The local SQLite file is not suitable
# for Lambda because the function filesystem is ephemeral.
# DATABASE_URL="libsql://your-database.turso.io"
# DATABASE_AUTH_TOKEN="your-database-auth-token"
# CORS_ORIGIN="https://your-frontend-domain.example"
# ADMIN_USERS_KEY="replace-with-a-strong-secret"
# GOOGLE_CLIENT_ID="your-production-google-oauth-client-id.apps.googleusercontent.com"
# UPLOADS_BUCKET="your-production-user-content-bucket"
# UPLOADS_PUBLIC_BASE_URL="https://your-production-user-content-bucket.s3.us-east-1.amazonaws.com"
# WEBSOCKET_CONNECTIONS_TABLE="your-websocket-connections-table"
# WEBSOCKET_API_ENDPOINT="https://your-websocket-api.execute-api.us-east-1.amazonaws.com/prod"
